{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI: run app",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload", "--port", "8000"],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "justMyCode": false
    },
    {
      "name": "Debug: interactive menu",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/debug.py",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Debug: all tests",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/debug.py",
      "args": ["all"],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Debug: shift CRUD",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/debug.py",
      "args": ["shift"],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Debug: optimize excel backlog",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/debug.py",
      "args": ["optimize-excel"],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "console": "integratedTerminal",
      "env": {
        "OPTIMIZER_DEBUG_CSV": "1"
      },
      "justMyCode": false
    },
    {
      "name": "Cloud backlog: fetch (REST POST)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/debug.py",
      "args": ["cloud-backlog"],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false
    },
    {
      "name": "Cloud backlog: PATCH work order",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/debug.py",
      "args": ["cloud-backlog-patch"],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false
    },
    {
      "name": "Python: current file",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
