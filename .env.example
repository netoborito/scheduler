# Copy to .env and fill in. Never commit .env.

# Optional: full backlog URL (if set, overrides base URL + path)
BACKLOG_REST_URL=

BACKLOG_INTEGRATION_BASE_URL=
BACKLOG_BACKLOG_PATH=
BACKLOG_INTEGRATION_API_KEY=
TENANT_ID=
ORGANIZATION=
GRID_ID=
DATASPY_ID=
# Base for PATCH /workorders/{id}; no trailing slash (e.g. https://host/.../services)
WORK_ORDER_API_BASE_URL=
# Work order id for debug.py cloud-backlog-patch (integer)
EAM_PATCH_WO_ID=
# Not used by current patch_eam_schedule_data in cloud_backlog_client (reserved / future)
EAM_PATCH_TEMPLATE_PATH=
# Optional: if set, write merged PATCH JSON body to this path after each patch_eam_schedule_data (debug)
EAM_PATCH_DEBUG_JSON=
# Optional: if set, write backlog DataFrame to this path after each successful fetch (debug)
BACKLOG_DEBUG_CSV=
BACKLOG_HTTP_TIMEOUT_SECONDS=30
