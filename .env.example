# Copy to .env and fill in. Never commit .env.

# Base URL for all EAM REST calls (e.g. https://host/axis/restservices)
INTEGRATION_BASE_URL=

# Path suffixes appended to INTEGRATION_BASE_URL
BACKLOG_ENDPOINT=
SCHEDULE_ENDPOINT=

# Auth & tenant
BACKLOG_INTEGRATION_API_KEY=
TENANT_ID=
ORGANIZATION=

# Grid / dataspy IDs for backlog fetch
GRID_ID=
DATASPY_ID=

# Optional
BACKLOG_HTTP_TIMEOUT_SECONDS=30
