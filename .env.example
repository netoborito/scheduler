# Copy to .env and fill in. Never commit .env.

# Backlog POST URL is BACKLOG_REST_URL + BACKLOG_ENDPOINT (use "" for endpoint if REST_URL is complete).
BACKLOG_REST_URL=

BACKLOG_INTEGRATION_BASE_URL=
BACKLOG_BACKLOG_PATH=
BACKLOG_ENDPOINT=
BACKLOG_INTEGRATION_API_KEY=
TENANT_ID=
ORGANIZATION=
GRID_ID=
DATASPY_ID=
# PATCH URL: absolute http(s) URL to the work-order collection base (WO id appended), or a path
# suffix after BACKLOG_REST_URL (slashes normalized), e.g. axis/services/workorders or
# https://host/.../api/workorders
SCHEDULE_ENDPOINT=
# Work order id for debug.py cloud-backlog-patch (integer)
EAM_PATCH_WO_ID=
# Optional: if set, write merged PATCH JSON body to this path after each patch_eam_schedule_data (debug)
EAM_PATCH_DEBUG_JSON=
# Optional: if set, write backlog DataFrame to this path after each successful fetch (debug)
BACKLOG_DEBUG_CSV=
BACKLOG_HTTP_TIMEOUT_SECONDS=30
